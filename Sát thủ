    task.spawn(function()
        local tweenInfo = TweenInfo.new(math.random(5, 15), Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1)
        TweenService:Create(Star, tweenInfo, {Position = UDim2.new(math.random(), 0, math.random(), 0)}):Play()
