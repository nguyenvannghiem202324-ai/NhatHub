local function UpdateSlider()
    local isDragging = false
    SliderBtn.MouseButton1Down:Connect(function() isDragging = true end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)
    
    task.spawn(function()
        while MainFrame.Parent do
            if isDragging then
                -- Hỗ trợ cả chuột máy tính và Touch Mobile
                local mousePos = UserInputService:GetMouseLocation().X
                local sliderPos = SliderBack.AbsolutePosition.X
                local sliderWidth = SliderBack.AbsoluteSize.X
                local percentage = math.clamp((mousePos - sliderPos) / sliderWidth, 0, 1)
                
                SliderBtn.Position = UDim2.new(percentage, -12, 0.5, -12)
                SliderFill.Size = UDim2.new(percentage, 0, 1, 0)
                
                -- Cập nhật tốc độ thực tế vào biến Settings
                local value = math.floor(16 + (percentage * 284)) -- Chạy từ 16 đến 300
                Settings.SpeedValue = value
                VelocityLabel.Text = "VELOCITY: " .. value
            end
            task.wait(0.01)
        end
    end)
end
UpdateSlider()

