-- ===================== LÕI LOGIC XỬ LÝ (CHẠY CHỨC NĂNG THỰC) =====================
RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    
    -- 1. XỬ LÝ TỐC ĐỘ (WARP SPEED)
    if char and char:FindFirstChild("Humanoid") then
        if Settings.SpeedHack then
            char.Humanoid.WalkSpeed = Settings.SpeedValue
        else
            char.Humanoid.WalkSpeed = 16 -- Tốc độ mặc định của Roblox
        end
    end
    
    -- 2. XỬ LÝ AUTO KILL V2 (Dịch chuyển & Đánh liên tục)
    if Settings.FastKillV2 and char and char:FindFirstChild("HumanoidRootPart") then
        local target = nil
        local minDist = Settings.KillRange
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
                local dist = (char.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    target = p.Character.HumanoidRootPart
                end
            end
        end
        
        if target then
            -- Dịch chuyển lên trên đầu quái/người chơi
            char:PivotTo(target.CFrame * CFrame.new(0, Settings.HeightOffset, 0))
            -- Spam click chuột (Auto Attack)
            for i = 1, Settings.AttackSpam do
                VirtualUser:Button1Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                VirtualUser:Button1Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
            end
        end
    end

    -- 3. XỬ LÝ ESP (XUYÊN TƯỜNG) VÀ HITBOX (PHÓNG TO MỤC TIÊU)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = p.Character.HumanoidRootPart
            
            -- Logic ESP
            if Settings.ESP and p.Character.Humanoid.Health > 0 then
                if not Boxes[p] then 
                    local b = Instance.new("BoxHandleAdornment", ESP_Folder)
                    b.Size = Vector3.new(4, 6, 4)
                    b.Color3 = Color3.fromRGB(0, 255, 255)
                    b.AlwaysOnTop = true
                    b.ZIndex = 10
                    b.Transparency = 0.7
                    Boxes[p] = b
                end
                Boxes[p].Adornee = hrp
            else 
                if Boxes[p] then Boxes[p].Adornee = nil end 
            end
            
            -- Logic Hitbox 150
            if Settings.Hitbox then
                hrp.Size = Vector3.new(150, 150, 150)
                hrp.Transparency = 0.8
                hrp.CanCollide = false
            else
                hrp.Size = Vector3.new(2, 2, 1) -- Size mặc định
                hrp.Transparency = 0
                hrp.CanCollide = true
            end
        end
    end
end)

