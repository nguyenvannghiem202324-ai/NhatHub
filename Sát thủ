local function CreateCosmicButton(name, pos, color, settingKey)
    local Button = Instance.new("TextButton", MainFrame)
    Button.Size = UDim2.new(0, 200, 0, 45)
    Button.Position = pos
    Button.BackgroundColor3 = Color3.fromRGB(20, 20, 40)
    Button.BackgroundTransparency = 0.3
    Button.Font = Enum.Font.GothamMedium
    Button.TextSize = 16
    Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 10)

    local Glow = Instance.new("UIStroke", Button)
    Glow.Thickness = 2
    Glow.Transparency = 0.4

    local function UpdateVisuals()
        local isOn = Settings[settingKey]
        local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Sine)
        if isOn then
            TweenService:Create(Button, tweenInfo, {TextColor3 = color}):Play()
            TweenService:Create(Glow, tweenInfo, {Color = color}):Play()
            TweenService:Create(Button, tweenInfo, {BackgroundColor3 = Color3.fromRGB(30, 60, 100)}):Play()
        else
            TweenService:Create(Button, tweenInfo, {TextColor3 = Color3.fromRGB(150, 150, 150)}):Play()
            TweenService:Create(Glow, tweenInfo, {Color = Color3.fromRGB(50, 50, 70)}):Play()
            TweenService:Create(Button, tweenInfo, {BackgroundColor3 = Color3.fromRGB(20, 20, 40)}):Play()
        end
        Button.Text = name .. (isOn and " [ON]" or " [OFF]")
    end

    UpdateVisuals()

    Button.MouseButton1Click:Connect(function()
        Settings[settingKey] = not Settings[settingKey] -- Thay đổi trạng thái thực tế
        UpdateVisuals()
    end)
end

