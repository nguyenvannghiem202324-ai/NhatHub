-- SỰ KIỆN NÚT BẤM
GetKeyBtn.MouseButton1Click:Connect(function()
    setclipboard(KeyLink)
    GetKeyBtn.Text = "ĐÃ COPY!"
    wait(1.5)
    GetKeyBtn.Text = "LẤY LINK"
end)

CheckBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == CorrectKey then
        -- Lưu Key vào bộ nhớ máy để lần sau tự nhập
        writefile(FileName, KeyInput.Text)
        
        CheckBtn.Text = "ĐANG LƯU..."
        wait(1)
        ScreenGui:Destroy()
        LoadMainScript()
    else
        KeyInput.Text = ""
        KeyInput.PlaceholderText = "SAI MÃ KHÓA!"
        wait(1.5)
        KeyInput.PlaceholderText = "Dán mã vào đây..."
    end
end)
