local CorrectKey = "NHATHUBKEY_76474"
local KeyLink = "https://loot-link.com/s?ASholoYf"
local FileName = "NhatHub_KeyAuth.txt" -- Tên file lưu key trong bộ nhớ máy

-- Hàm thực thi script chính
local function LoadMainScript()
    print("Đang tải không gian BladeSpin...")
    loadstring(game:HttpGet("https://raw.githubusercontent.com/gumanba/Scripts/main/BladeSpin"))()
end

-- KIỂM TRA AUTO KEY KHI VỪA MỞ SCRIPT
if isfile(FileName) then
    local SavedKey = readfile(FileName)
    if SavedKey == CorrectKey then
        -- Nếu key lưu trong máy vẫn đúng, vào thẳng script luôn
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "NHAT HUB",
            Text = "Đã tự động xác thực mã vũ trụ!",
            Duration = 5
        })
        LoadMainScript()
        return -- Dừng đoạn code bên dưới, không hiện UI nhập key nữa
    end
end

-- NẾU CHƯA CÓ KEY HOẶC KEY SAI, HIỆN GIAO DIỆN (UI) NHƯ CŨ
